        },
        {
            "fieldname": "failover_html",
            "fieldtype": "HTML",
            "label": "Failover Info",
            "options": "<div class='alert alert-info' style='border-radius:8px;padding:12px'><b>🔄 How Failover Works</b><br>Add multiple API keys below. When one key's quota is exhausted (rate limit / daily limit), the system <b>automatically switches</b> to the next key.<br><br><b>Tip:</b> Create 2-3 free API keys from different Google accounts for uninterrupted service.<br><b>Priority:</b> Primary Key → Failover Key 2 → Failover Key 3 → site_config.json GEMINI_API_KEY</div>"
        },
