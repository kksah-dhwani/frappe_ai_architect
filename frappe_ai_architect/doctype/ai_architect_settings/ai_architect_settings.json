        {
            "depends_on": "eval:!doc.is_setup_complete",
            "fieldname": "setup_html",
            "fieldtype": "HTML",
            "label": "Setup Guide",
            "options": "<div class='alert alert-warning' style='border-left:4px solid #f39c12;padding:16px;border-radius:8px;margin:8px 0'><h4 style='margin:0 0 8px'>🚀 Welcome! Setup in 3 Easy Steps</h4><ol style='margin:8px 0;padding-left:20px'><li style='margin:6px 0'><b>Get Free API Key:</b> Go to <a href='https://aistudio.google.com/apikey' target='_blank' style='color:#6C5CE7;font-weight:600'>Google AI Studio ↗</a> → Click \"Create API Key\" → Copy</li><li style='margin:6px 0'><b>Paste Below:</b> Paste your key in the \"Primary API Key\" field</li><li style='margin:6px 0'><b>Save:</b> Click Save → Done! 🎉</li></ol><p style='margin:8px 0 0;color:#666;font-size:12px'>✅ Free: 15 req/min, 1500/day — no credit card needed<br>🔒 Keys stored securely as encrypted password fields</p></div>"
        },
        {
            "fieldname": "api_section",
            "fieldtype": "Section Break",
            "label": "Gemini API"
        },
        {
            "fieldname": "api_key",
            "fieldtype": "Password",
            "label": "Primary API Key",
            "reqd": 1,
            "description": "Get free key from <a href='https://aistudio.google.com/apikey' target='_blank'>Google AI Studio</a>"
        },
